{
  "manifest_version": 3,
  "name": "Note-It",
  "version": "1.0.0",
  "description": "A notes app for your browser. Add, delete, and organize notes by category.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Note-It",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage"]
}
